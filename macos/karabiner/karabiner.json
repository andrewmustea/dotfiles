                ],
                "from": {
                  "key_code": "escape",
                  "modifiers": { "mandatory": ["control"] }
                },
                "to": [
                  {
                    "key_code": "launchpad",
                    "modifiers": []
                  }
                ],
                "type": "basic"
              }
            ]
          }
        ]
