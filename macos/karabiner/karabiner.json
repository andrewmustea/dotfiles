                      "^com\\.vmware\\.fusion$",
                      "^com\\.vmware\\.horizon$",
                      "^com\\.vmware\\.view$",
                      "^com\\.parallels\\.desktop$",
                      "^com\\.parallels\\.vm$",
                      "^com\\.parallels\\.desktop\\.console$",
                      "^org\\.virtualbox\\.app\\.VirtualBoxVM$",
