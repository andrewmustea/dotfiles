      "complex_modifications": {
        "rules": [
          {
            "description": "Forward delete (Ctrl-delete)",
            "manipulators": [
              {
                "from": {
                  "key_code": "delete_or_backspace",
                  "modifiers": {
                    "mandatory": ["left_control"],
                    "optional": ["caps_lock"]
                  }
                },
                "to": [{ "key_code": "delete_forward" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Command+E Opens Finder",
            "manipulators": [
              {
                "conditions": [
                  {
                    "bundle_identifiers": [
                      "^com\\.microsoft\\.rdc$",
                      "^com\\.microsoft\\.rdc\\.",
                      "^net\\.sf\\.cord$",
                      "^com\\.thinomenon\\.RemoteDesktopConnection$",
                      "^com\\.itap-mobile\\.qmote$",
                      "^com\\.nulana\\.remotixmac$",
                      "^com\\.p5sys\\.jump\\.mac\\.viewer$",
                      "^com\\.p5sys\\.jump\\.mac\\.viewer\\.",
                      "^com\\.teamviewer\\.TeamViewer$",
                      "^com\\.vmware\\.horizon$",
                      "^com\\.2X\\.Client\\.Mac$",
                      "^com\\.OpenText\\.Exceed-TurboX-Client$",
                      "^com\\.realvnc\\.vncviewer$",
                      "^com\\.citrix\\.receiver\\.icaviewer",
                      "^com\\.vmware\\.fusion$",
                      "^com\\.vmware\\.horizon$",
                      "^com\\.vmware\\.view$",
                      "^com\\.parallels\\.desktop$",
                      "^com\\.parallels\\.vm$",
                      "^com\\.parallels\\.desktop\\.console$",
                      "^org\\.virtualbox\\.app\\.VirtualBoxVM$",
                      "^com\\.citrix\\.XenAppViewer$",
                      "^com\\.vmware\\.proxyApp\\.",
                      "^com\\.parallels\\.winapp\\.",
                      "^com\\.utmapp\\.UTM$"
                    ],
                    "type": "frontmost_application_unless"
                  }
                ],
                "from": {
                  "key_code": "e",
                  "modifiers": { "mandatory": ["command"] }
                },
                "to": [{ "shell_command": "open -a 'Finder.app'" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Control+Esc Opens Launchpad",
            "manipulators": [
